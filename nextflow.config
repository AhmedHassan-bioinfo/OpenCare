// ======================================================================
// OpenCare — Nextflow config 
// - Single docker/runOptions block
// - Run containers as root to avoid workdir write issues
// - Mount VEP cache read-only at the SAME path used by --vep_cache
// ======================================================================

/* --------------------------- executor & process --------------------------- */
process {
  executor      = 'local'
  scratch       = false
  stageInMode   = 'copy'
  stageOutMode  = 'copy'
  errorStrategy = 'terminate'  // use 'retry' in production
  maxRetries    = 0
  shell         = ['/bin/bash','-euo','pipefail']

  // Run everything as root inside containers (fixes .command.* write perms)
  containerOptions = '-u 0:0'

  // Common per-task time limits (override below where needed)
  time = '72h'

  /* ---------- Per-process images & tuning ---------- */
  withName: REF_FAIDX          { cpus = 2;  container = 'quay.io/biocontainers/samtools:1.17--h00cdaf9_0' }
  withName: BWA_INDEX          { cpus = 2;  container = 'quay.io/biocontainers/bwa:0.7.17--he4a0461_11' }
  withName: FASTQC_RAW         {          container = 'quay.io/biocontainers/fastqc:0.11.9--0';  time = '24h' }
  withName: FASTQC_TRIM        {          container = 'quay.io/biocontainers/fastqc:0.11.9--0' }
  withName: TRIM_FASTP         {          container = 'quay.io/biocontainers/fastp:0.23.4--h5f740d0_0'; time = '24h' }
  withName: ALIGN_BWA          {
    container = 'quay.io/biocontainers/bwa:0.7.17--he4a0461_11'
    // Optional hard limit for the container if you want cgroup enforcement:
    containerOptions = '-u 0:0 --memory=20g --memory-swap=20g'
  }
  withName: SAMTOOLS_SORT_INDEX { container = 'quay.io/biocontainers/samtools:1.17--h00cdaf9_0' }
  withName: MARKDUPS           { container = 'broadinstitute/gatk:4.5.0.0' }
  withName: REINDEX_CRAM       { container = 'quay.io/biocontainers/samtools:1.17--h00cdaf9_0' }
  withName: CALL_VARIANTS_CRAM { container = 'quay.io/biocontainers/bcftools:1.17--h3cc50cf_1' }
  withName: CALL_SOMATIC_MUTECT2 { container = 'broadinstitute/gatk:4.5.0.0' }

  // Picard CreateSequenceDictionary can be memory-hungry; give it heap
  withName: REF_DICT {
    container        = 'broadinstitute/gatk:4.5.0.0'
    time = '1h'
  }

  withName: VEP_ANNOTATE       { container = 'ensemblorg/ensembl-vep:release_110.1'; time = '12h' }
  withName: FILTER_FOR_HTML    { container = 'quay.io/biocontainers/bcftools:1.17--h3cc50cf_1' }
  withName: MAKE_JSON_SUMMARY  { container = 'python:3.11'; time = '6h' }
  withName: MAKE_SLIM_JSON     { container = 'python:3.11' }
  withName: BUILD_HTML         { container = 'python:3.11'; time = '1h' }

  // Panel QC via mosdepth (container) — comment out to run on host instead
  withName: PANEL_QC_MOSDEPTH  { container = 'quay.io/biocontainers/mosdepth:0.3.3--hdfd78af_2' }

  // This task shells out to samtools + Python; run on host to ensure both exist
  // (leave as-is if your host has `samtools` and `python3` available)
  withName: 'ClinicalCore:QC_AGGREGATE' {
    container = null    // no container: use host tools
    time = '2h'
  }

  // JSON builder tuning example
  withName: 'ClinicalCore:MAKE_JSON_SUMMARY' {
    memory           = '8 GB'
    containerOptions = '-u 0:0 -e MAX_ROWS=300000'
  }
}
process {
  withName: 'PANEL_QC_MOSDEPTH' {
    stageInMode = 'copy'
  }
  withName: 'ClinicalCore:PANEL_QC_MOSDEPTH' {
    stageInMode = 'copy'
  }
}
process {
  withName: 'REF_DICT' {
    container = 'quay.io/biocontainers/samtools:1.17--h00cdaf9_0'
    shell = ['/bin/bash','-e','-o','pipefail']
    memory    = '2 GB'
    time      = '1h'
  }
}
process {
  withName: 'ClinicalCore:PANEL_QC_MOSDEPTH' {
    container   = null           // use host binaries
    stageInMode = 'copy'         // avoid cross-device hardlink errors
    shell       = ['/bin/bash','-euo','pipefail']
  }
  withName: 'ClinicalCore:QC_AGGREGATE' {
    container   = null           // uses host samtools + python
  }
}

process {
  withName: 'ClinicalCore:MAKE_JSON_SUMMARY' {
    // keep your existing settings here (memory, containerOptions, etc.)
    env = [
      'REPORT_MIN_QUAL':    '0',   // allow Mutect2 (QUAL=".")
      'REPORT_MIN_DP':      '0',   // DP already enforced upstream
      'REPORT_REQUIRE_PASS':'1',   // still require PASS
      // leave coding/impact as you prefer; for a smoke test you can set coding_only=0
      // 'REPORT_CODING_ONLY': '0', // (optional for smoke test if VEP CSQ absent)
    ]
  }
}

params.mosdepth_bin = 'mosdepth'   // or absolute path, e.g. "$HOME/bin/mosdepth"
params.samtools_bin = 'samtools'

/* ------------------------------- docker ---------------------------------- */
docker {
  enabled      = true
  fixOwnership = true
  // Mount the VEP cache read-only at the SAME absolute path you pass to --vep_cache
  // Also give containers a tmpfs with exec so VEP can write temp files
  runOptions   = '-u 0:0 -v /OpenCare_project/vep_cache:/OpenCare_project/vep_cache:ro --tmpfs /tmp:exec'
}

/* -------------------------------- paths ---------------------------------- */
workDir       = '/home/user/nxf_work'
params.outdir = '/mnt/e/OpenCare_project/results'
params.gnomad_vcf = '/mnt/e/OpenCare_project/resources/gnomad/somatic-hg38_af-only-gnomad.hg38.vcf.gz'

/* -------------------------------- params --------------------------------- */
params.max_cpus = 6
params.max_mem  = '24 GB'
params.max_time = '200h'
params {
  civic_offline = "$projectDir/resources/CivicDB/civic_offline.json"
  trace_file        = "${outdir}/trace.tsv"
}
trace {
  enabled   = true
  file      = params.trace_file
  sep       = '\t'
  overwrite = true

  // IMPORTANT: no "cputime" here
  fields = 'task_id,hash,process,tag,name,status,exit,submit,start,complete,duration,realtime,%cpu,%mem,peak_rss,peak_vmem,read_bytes,write_bytes,workdir,container'
}
// Match the docker mount above; you will pass --vep_cache "/OpenCare_project/vep_cache"
params.vep_cache   = '/OpenCare_project/vep_cache'

// Tools on host (used by QC_AGGREGATE or if you disable containers for a step)
params.samtools_bin = 'samtools'
params.mosdepth_bin = 'mosdepth'

// Panel settings (used when you set --assay panel)
params.panel_bed  = "${projectDir}/resources/panel/panel.hg38.coding+10bp.bed"
params.panel_name = 'GENCODE_exons_+10bp_hg38'
params.assay      = 'panel'

// Optional targets (leave null unless needed)
params.targets_bed = null
params {
  pathway_db = "$projectDir/resources/pathway_gene_map_v1.json"
}
process {
  withName: BUILD_HTML {
    // DON'T: ext.args = "--pathway-db ${file('...')}"
    ext.args = "--pathway-db ${params.pathway_db}"
  }
}

// HTML builder
params.report_builder = 'html'
params.build_html     = "$baseDir/HTML/build_html.py"

// Reporting controls
params.report_keep_impact  = 'HIGH,MODERATE'
params.report_max_per_gene = 50
params.report_max_rows     = 100000
params.report_search_limit = 0
params.report_export_tsv   = 1
params {
  filter_min_qual_germline = 30
  filter_min_dp_germline   = 10
  filter_min_dp_somatic    = 8
  filter_min_vaf_somatic   = 0.02
}
params.enable_civic    = true
params.enable_evidence = true
// Evidence / online enrichment flags
params.enable_online  = false
params.enable_evidence = true
params.oncokb_token    = null
params.gene_domains    = null
params.mcode           = null
params.ncbi_key        = null
params.ncbi_email      = null
params.msk_hotspot_keys = '/mnt/e/OpenCare_project/resources/hotspots/msk_cancer_hotspots.keys.tsv'
// Misc
params.empty_json = "$baseDir/.empty.json"
params.empty_tsv  = "$baseDir/.empty.tsv"
trace {
  enabled = true
  file    = params.trace_file
  sep     = '\t'
  fields  = 'task_id,hash,native_id,process,tag,name,status,exit,submit,start,complete,duration,realtime,cpus,%cpu,%mem,rss,vmem,peak_rss,peak_vmem,rchar,wchar,read_bytes,write_bytes,workdir'
}



process {
  shell = ['/bin/bash', '-e', '-o', 'pipefail']   // NO -u
}
process.shell = ['/bin/bash', '-e', '-o', 'pipefail']   // NO -u
